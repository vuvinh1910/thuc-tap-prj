# ── Application ──────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Provider Selection ───────────────────────────────────────────────────
LLM_PROVIDER=anthropic
EMBEDDING_PROVIDER=openai

# ── API Keys (REQUIRED) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI Models ────────────────────────────────────────────────────────
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536
OPENAI_LLM_MODEL=gpt-4o-mini

# ── Anthropic Models ─────────────────────────────────────────────────────
ANTHROPIC_LLM_MODEL=claude-3-5-haiku-20241022

# ── Ollama Models ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2

# ── Qdrant ───────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=legal_docs

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ragbot
POSTGRES_PASSWORD=ragbot_secret
POSTGRES_DB=ragbot_db
DATABASE_URL=postgresql+asyncpg://ragbot:ragbot_secret@localhost:5432/ragbot_db

# ── Redis / Celery ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── File Storage ─────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Chunking ─────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNKING_STRATEGY=recursive

# ── RAG Retrieval ────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.35
